# Neon PostgreSQL connection string (from neon.tech dashboard)
DATABASE_URL=postgresql://user:password@host/dbname

# Gmail sender account
EMAIL_USER=your@gmail.com

# Gmail App Password (not your regular password)
# Create at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your-app-password

# Where to send notifications
NOTIFY_EMAIL=your@gmail.com

# Access approval system
ADMIN_EMAIL=your@gmail.com          # The master admin email (auto-approved)
ADMIN_SECRET=your-random-secret     # Secret for signing approve/deny tokens (use a long random string)
NEXT_PUBLIC_APP_URL=https://anime-project-beige.vercel.app   # Full URL of the app (used in email links)
