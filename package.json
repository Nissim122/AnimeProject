{
  "name": "anime-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:related": "vitest related --run",
    "test:lib": "vitest run --project lib",
    "test:api-track": "vitest run --project api-track",
    "test:api-watchlist": "vitest run --project api-watchlist",
    "test:api-onhold": "vitest run --project api-onhold",
    "test:api-search": "vitest run --project api-search",
    "test:api-seasons": "vitest run --project api-seasons",
    "test:api-next-seasons": "vitest run --project api-next-seasons",
    "test:api-airing": "vitest run --project api-airing",
    "test:api-check-updates": "vitest run --project api-check-updates",
    "test:api-check-episodes": "vitest run --project api-check-episodes",
    "test:api-cache-refresh": "vitest run --project api-cache-refresh",
    "test:api-admin": "vitest run --project api-admin",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.16",
    "@prisma/client": "^6.0.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.10",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "husky": "^9.1.7",
    "playwright": "^1.60.0",
    "postcss": "^8.4.47",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
