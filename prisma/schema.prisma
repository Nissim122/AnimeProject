generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TrackedAnime {
  id              Int           @id @default(autoincrement())
  anilistId       Int           @unique
  title           String
  coverImage      String?
  trackedAt       DateTime      @default(now())
  watchedEpisodes Int           @default(0)
  totalEpisodes   Int?
  knownSequels    KnownSequel[]
}

model KnownSequel {
  id              Int          @id @default(autoincrement())
  trackedAnimeId  Int
  sequelAnilistId Int
  trackedAnime    TrackedAnime @relation(fields: [trackedAnimeId], references: [id], onDelete: Cascade)

  @@unique([trackedAnimeId, sequelAnilistId])
}

model SentNotification {
  id              Int      @id @default(autoincrement())
  sequelAnilistId Int
  type            String   @default("MONTH_START")
  sequelTitle     String
  parentTitle     String
  sentAt          DateTime @default(now())

  @@unique([sequelAnilistId, type])
}

model WatchListItem {
  id         Int      @id @default(autoincrement())
  anilistId  Int      @unique
  title      String
  coverImage String?
  addedAt    DateTime @default(now())
}
