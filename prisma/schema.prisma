generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TrackedAnime {
  id           Int           @id @default(autoincrement())
  userId       String
  anilistId    Int
  title        String
  coverImage   String?
  trackedAt    DateTime      @default(now())
  knownSequels KnownSequel[]

  @@unique([userId, anilistId])
}

model KnownSequel {
  id              Int          @id @default(autoincrement())
  trackedAnimeId  Int
  sequelAnilistId Int
  trackedAnime    TrackedAnime @relation(fields: [trackedAnimeId], references: [id], onDelete: Cascade)

  @@unique([trackedAnimeId, sequelAnilistId])
}

model SentNotification {
  id              Int      @id @default(autoincrement())
  userId          String
  sequelAnilistId Int
  type            String   @default("MONTH_START")
  sequelTitle     String
  parentTitle     String
  sentAt          DateTime @default(now())

  @@unique([userId, sequelAnilistId, type])
}

model WatchListItem {
  id         Int      @id @default(autoincrement())
  userId     String
  anilistId  Int
  title      String
  coverImage String?
  addedAt    DateTime @default(now())

  @@unique([userId, anilistId])
}
