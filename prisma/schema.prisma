generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TrackedAnime {
  id           Int           @id @default(autoincrement())
  userId       String
  anilistId    Int
  title        String
  coverImage   String?
  note         String?
  trackedAt    DateTime      @default(now())
  knownSequels KnownSequel[]

  @@unique([userId, anilistId])
}

model KnownSequel {
  id              Int          @id @default(autoincrement())
  trackedAnimeId  Int
  sequelAnilistId Int
  trackedAnime    TrackedAnime @relation(fields: [trackedAnimeId], references: [id], onDelete: Cascade)

  @@unique([trackedAnimeId, sequelAnilistId])
}

model SentNotification {
  id              Int      @id @default(autoincrement())
  userId          String
  sequelAnilistId Int
  type            String   @default("MONTH_START")
  sequelTitle     String
  parentTitle     String
  sentAt          DateTime @default(now())

  @@unique([userId, sequelAnilistId, type])
}

model WatchListItem {
  id         Int      @id @default(autoincrement())
  userId     String
  anilistId  Int
  title      String
  coverImage String?
  addedAt    DateTime @default(now())

  @@unique([userId, anilistId])
}

model OnHoldItem {
  id         Int      @id @default(autoincrement())
  userId     String
  anilistId  Int
  title      String
  coverImage String?
  note       String?
  addedAt    DateTime @default(now())

  @@unique([userId, anilistId])
}

model SeasonCache {
  anilistId   Int      @id
  seasonsJson String
  updatedAt   DateTime @updatedAt
}

model StatusCache {
  anilistId    Int      @id
  status       String
  startDateJson String
  sequelsJson  String
  updatedAt    DateTime @updatedAt
}

model UserApproval {
  id          Int       @id @default(autoincrement())
  clerkUserId String    @unique
  email       String
  name        String?
  status      String    @default("PENDING")
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
